---
// Full-bleed city header for a chapter page — faithful to harvardintech.com:
// a background photo with a dark overlay and centered light text, an uppercase
// "HARVARD IN TECH <CITY>" title (the "fresh" theme's flanking-rule treatment,
// mirroring landing/Hero.astro) and the `tagline` subtitle beneath it. The
// background is rendered as an <img> (survives the preview reverse-proxy /
// base-path rewrite). When `heroImage` is absent we fall back to the original
// centered ChapterHeader so a chapter with no image still renders.
import ChapterHeader from './ChapterHeader.astro';
import { withBase } from '../lib/url';

interface Props {
  city: string;
  region?: string;
  blurb?: string;
  heroImage?: string;
  tagline?: string;
}
const { city, region, blurb, heroImage, tagline } = Astro.props;
const title = `Harvard in Tech ${city}`;
---

{
  heroImage ? (
    <section class="chapter-hero">
      <div style="position: absolute; inset: 0; overflow: hidden; z-index: 0;">
        <img
          src={withBase(heroImage)}
          alt=""
          style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;"
        />
        <div style="position: absolute; inset: 0; background: rgba(0, 0, 0, 0.39);" />
      </div>
      <div class="chapter-hero-inner">
        <h1 class="chapter-hero-title">{title}</h1>
        {tagline ? <p class="chapter-hero-tagline">{tagline}</p> : null}
      </div>
    </section>
  ) : (
    <ChapterHeader city={city} region={region} blurb={blurb} />
  )
}

<style>
  .chapter-hero {
    position: relative;
    box-sizing: border-box;
    /* Fill the first screen below the header, like the live chapter pages.
       `min-height` (not `height`) so content never clips on short screens;
       `svh` avoids the mobile address-bar jump, with a `vh` fallback. */
    min-height: calc(100vh - var(--header-height));
    min-height: calc(100svh - var(--header-height));
    padding: 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
  .chapter-hero-inner {
    position: relative;
    z-index: 2;
    max-width: 918px;
    margin: 0 auto;
    color: #fff;
    text-align: center;
  }
  .chapter-hero-title {
    text-transform: uppercase;
    font-family: var(--font-title);
    font-weight: 400;
    color: #fff;
    font-size: 58px;
    line-height: 1.2;
    letter-spacing: normal;
    white-space: nowrap;
    margin: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  /* "fresh" theme title decoration: 80x2px white rules flanking the text */
  .chapter-hero-title::before,
  .chapter-hero-title::after {
    content: '';
    flex: none;
    width: 80px;
    height: 2px;
    margin: 0 10px;
    background: #fff;
  }
  .chapter-hero-tagline {
    font-family: var(--font-sans);
    font-size: 20px;
    font-weight: 400;
    line-height: 29px;
    color: #fff;
    margin: 1.5rem 0 0;
  }

  /* Mobile: the title scales down, wraps left-aligned, and the flanking rules
     collapse to a single underline beneath it — matching landing/Hero. */
  @media (max-width: 640px) {
    .chapter-hero {
      padding: 24px;
    }
    .chapter-hero-inner {
      text-align: left;
    }
    .chapter-hero-title {
      display: block;
      text-align: left;
      white-space: normal;
      font-size: 36px;
      line-height: 1.15;
      margin: 0;
    }
    .chapter-hero-title::before {
      display: none;
    }
    .chapter-hero-title::after {
      display: block;
      width: 80px;
      margin: 1rem 0 0;
    }
    .chapter-hero-tagline {
      font-size: 17px;
      line-height: 26px;
    }
  }
</style>
