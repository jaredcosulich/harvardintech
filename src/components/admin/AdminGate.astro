---
// Client-side passcode gate for the /admin dashboard. Mounted as the first child
// of <body> in AdminLayout, so it covers every page rendered through that shell.
//
// DETERRENT, NOT SECURITY (see src/lib/adminGate.ts for the full caveat): on a
// static GitHub Pages site the passcode ships in the HTML. This only keeps the
// dashboard from being stumbled into. The real write-access boundary is each
// editor's GitHub token (Contents: Read & Write), entered via Sveltia's "Sign in
// with Token" — without a valid token no commit can land.
//
// PRODUCTION-ONLY. The gate's blocking script is emitted only for production
// builds (`import.meta.env.PROD`). On a local dev server / the codeyam preview
// the dashboard is left open — same "local is trusted, no auth" stance as
// `local_backend: true` in the editor config — so editing and scenario capture
// stay frictionless. The deterrent matters only on the public deployment.
import { withBase } from '../../lib/url';
import { ADMIN_GATE_STORAGE_KEY } from '../../lib/adminGate';

// Build-time passcode. Real value comes from the ADMIN_GATE_PASSCODE env var set
// in CI; the clearly-named fallback only keeps local production builds from
// breaking when it is unset (it is not a secret — see the module caveat).
const expectedPasscode =
  import.meta.env.ADMIN_GATE_PASSCODE ?? 'harvardintech-admin-preview';

// Base-aware public home, used when a visitor cancels or fails the prompt.
const homePath = withBase('/');

const gateActive = import.meta.env.PROD;
---

{
  gateActive && (
    <script
      is:inline
      define:vars={{
        expected: expectedPasscode,
        storageKey: ADMIN_GATE_STORAGE_KEY,
        homePath,
      }}
    >
      {
        // Runs before the rest of <body> is parsed. Mirrors isPasscodeCorrect()
        // from src/lib/adminGate.ts (an inline script can't import the bundled
        // module). Hide the document up front to avoid flashing the dashboard,
        // then show a custom, opaque full-viewport overlay with a masked
        // <input type="password"> so the typed passcode renders as dots (the
        // native window.prompt cannot mask). Reveal on a correct passcode,
        // redirect home on cancel / Escape / an incorrect entry. The overlay's
        // look mirrors src/components/admin/AdminGatePrompt.astro — keep the two
        // in sync; that component is the isolable visual spec of this prompt.
      }
      (function () {
        try {
          if (sessionStorage.getItem(storageKey) === '1') return;
        } catch (e) {
          // sessionStorage blocked (private mode / disabled) — fall through to prompt.
        }
        var root = document.documentElement;
        var prev = root.style.visibility;
        // Hide everything up front so the dashboard never flashes behind the overlay.
        root.style.visibility = 'hidden';
        var want = String(expected).trim();

        function goHome() {
          window.location.replace(homePath);
        }

        // Opaque, full-viewport backdrop. Its own visibility:visible overrides
        // the inherited `hidden`, and a near-max z-index keeps the dashboard covered.
        var backdrop = document.createElement('div');
        backdrop.setAttribute('role', 'dialog');
        backdrop.setAttribute('aria-modal', 'true');
        backdrop.setAttribute('aria-label', 'Admin passcode');
        backdrop.style.cssText = [
          'position:fixed',
          'inset:0',
          'z-index:2147483647',
          'visibility:visible',
          'display:flex',
          'align-items:center',
          'justify-content:center',
          'padding:24px',
          'background:var(--color-bg-soft, #f5f7f9)',
          'font-family:var(--font-sans, Helvetica, Arial, sans-serif)',
        ].join(';');

        // Use a <form> so Enter submits naturally.
        var card = document.createElement('form');
        card.style.cssText = [
          'box-sizing:border-box',
          'width:100%',
          'max-width:360px',
          'display:flex',
          'flex-direction:column',
          'gap:14px',
          'padding:28px 24px',
          'background:var(--color-bg, #ffffff)',
          'border:1px solid var(--color-border, #e3e7ea)',
          'border-radius:var(--radius, 4px)',
          'box-shadow:0 8px 28px rgba(0,0,0,0.16)',
        ].join(';');

        var label = document.createElement('label');
        label.textContent = 'Enter the admin passcode to continue';
        label.style.cssText =
          'font-size:15px;font-weight:600;color:var(--color-fg, #2e2e2f);';

        var input = document.createElement('input');
        input.type = 'password';
        input.autocomplete = 'current-password';
        input.setAttribute('aria-label', 'Admin passcode');
        input.style.cssText = [
          'box-sizing:border-box',
          'width:100%',
          'padding:10px 12px',
          'font-size:15px',
          'border:1px solid var(--color-border, #e3e7ea)',
          'border-radius:var(--radius, 4px)',
          'outline:none',
        ].join(';');
        label.htmlFor = 'admin-gate-input';
        input.id = 'admin-gate-input';

        var actions = document.createElement('div');
        actions.style.cssText =
          'display:flex;gap:8px;justify-content:flex-end;align-items:center;';

        var cancel = document.createElement('button');
        cancel.type = 'button';
        cancel.textContent = 'Cancel';
        cancel.style.cssText = [
          'padding:9px 14px',
          'font-size:14px',
          'background:transparent',
          'color:var(--color-muted, #555555)',
          'border:none',
          'border-radius:var(--radius, 4px)',
          'cursor:pointer',
        ].join(';');

        var unlock = document.createElement('button');
        unlock.type = 'submit';
        unlock.textContent = 'Unlock';
        unlock.style.cssText = [
          'padding:9px 18px',
          'font-size:14px',
          'font-weight:600',
          'color:#ffffff',
          'background:var(--color-accent, #0ca5a5)',
          'border:none',
          'border-radius:var(--radius, 4px)',
          'cursor:pointer',
        ].join(';');

        actions.appendChild(cancel);
        actions.appendChild(unlock);
        card.appendChild(label);
        card.appendChild(input);
        card.appendChild(actions);
        backdrop.appendChild(card);
        // documentElement exists even before <body> finishes parsing.
        root.appendChild(backdrop);
        input.focus();

        function submit() {
          var entry = input.value;
          if (want.length > 0 && entry.trim() === want) {
            try {
              sessionStorage.setItem(storageKey, '1');
            } catch (e) {
              // Can't persist the unlock; the page still reveals for this view.
            }
            backdrop.remove();
            root.style.visibility = prev || '';
          } else {
            // Incorrect entry — same redirect-home behavior as the old prompt.
            goHome();
          }
        }

        card.addEventListener('submit', function (ev) {
          ev.preventDefault();
          submit();
        });
        cancel.addEventListener('click', goHome);
        document.addEventListener('keydown', function (ev) {
          if (ev.key === 'Escape') goHome();
        });
      })();
    </script>
  )
}
