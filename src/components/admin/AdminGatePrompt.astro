---
// Visual spec of the /admin passcode prompt overlay. This is the isolable,
// server-rendered twin of the overlay that AdminGate.astro builds at runtime via
// document.createElement (an inline gate script can't import a bundled component,
// so the two are kept in sync by hand — same pattern as the inline script
// mirroring isPasscodeCorrect from src/lib/adminGate.ts).
//
// The real gate is PRODUCTION-ONLY and builds its overlay imperatively, so it
// never renders on the dev server / codeyam preview. This component exists so the
// masked prompt can still be shown as a scenario: it renders the same card,
// masked <input type="password">, and Unlock / Cancel affordances statically.
//
// `value` pre-fills the password field so the capture shows the characters
// masked to dots. Rendered inside a relatively-positioned, sized frame (not the
// real position:fixed backdrop) so the isolation harness captures real bounds.
interface Props {
  value?: string;
}
const { value = '' } = Astro.props;
---

<div class="admin-gate-prompt">
  <form class="admin-gate-prompt__card" onsubmit="return false">
    <label class="admin-gate-prompt__label" for="admin-gate-prompt-input">
      Enter the admin passcode to continue
    </label>
    <input
      id="admin-gate-prompt-input"
      class="admin-gate-prompt__input"
      type="password"
      value={value}
      aria-label="Admin passcode"
      autocomplete="current-password"
    />
    <div class="admin-gate-prompt__actions">
      <button type="button" class="admin-gate-prompt__cancel">Cancel</button>
      <button type="submit" class="admin-gate-prompt__unlock">Unlock</button>
    </div>
  </form>
</div>

<style>
  /* Mirrors the inline overlay styles in AdminGate.astro. Tokens with literal
     fallbacks, since the real overlay may paint before tokens.css applies. */
  .admin-gate-prompt {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 420px;
    padding: 24px;
    background: var(--color-bg-soft, #f5f7f9);
    font-family: var(--font-sans, Helvetica, Arial, sans-serif);
  }
  .admin-gate-prompt__card {
    box-sizing: border-box;
    width: 100%;
    max-width: 360px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 28px 24px;
    background: var(--color-bg, #ffffff);
    border: 1px solid var(--color-border, #e3e7ea);
    border-radius: var(--radius, 4px);
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.16);
  }
  .admin-gate-prompt__label {
    font-size: 15px;
    font-weight: 600;
    color: var(--color-fg, #2e2e2f);
  }
  .admin-gate-prompt__input {
    box-sizing: border-box;
    width: 100%;
    padding: 10px 12px;
    font-size: 15px;
    border: 1px solid var(--color-border, #e3e7ea);
    border-radius: var(--radius, 4px);
    outline: none;
  }
  .admin-gate-prompt__actions {
    display: flex;
    gap: 8px;
    justify-content: flex-end;
    align-items: center;
  }
  .admin-gate-prompt__cancel {
    padding: 9px 14px;
    font-size: 14px;
    background: transparent;
    color: var(--color-muted, #555555);
    border: none;
    border-radius: var(--radius, 4px);
    cursor: pointer;
  }
  .admin-gate-prompt__unlock {
    padding: 9px 18px;
    font-size: 14px;
    font-weight: 600;
    color: #ffffff;
    background: var(--color-accent, #0ca5a5);
    border: none;
    border-radius: var(--radius, 4px);
    cursor: pointer;
  }
</style>
