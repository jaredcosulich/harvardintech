---
// The CRM admin top bar: the site wordmark on the left and a "Content Manager"
// label on the right. Plain chrome — no nav, no public-site links — so the
// editing surface reads as distinct from the public site.
interface Props {
  siteTitle: string;
}
const { siteTitle } = Astro.props;
---

<header style="background: var(--color-bg); border-bottom: 1px solid var(--color-border);">
  <div
    style="max-width: var(--content-width); margin: 0 auto; padding: var(--space-md) var(--space-lg); display: flex; align-items: baseline; justify-content: space-between; gap: var(--space-md);"
  >
    <span
      style="font-family: var(--font-title); font-weight: 500; font-size: 1.15rem; color: var(--color-fg);"
      >{siteTitle}</span
    >
    <span
      style="text-transform: uppercase; letter-spacing: 0.12em; font-size: 0.8rem; color: var(--color-muted);"
      >Content Manager</span
    >
  </div>
</header>
