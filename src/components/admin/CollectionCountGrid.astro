---
// The responsive grid of per-collection count cards. Pure layout: it maps each
// card descriptor to a CollectionCountCard and threads the editor link through.
import CollectionCountCard from './CollectionCountCard.astro';
import type { CollectionCard } from '../../lib/adminDashboard';

interface Props {
  cards: CollectionCard[];
  editorHref: string;
}
const { cards, editorHref } = Astro.props;
---

<section
  style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: var(--space-md);"
>
  {
    cards.map((card) => (
      <CollectionCountCard
        collection={card.collection}
        label={card.label}
        count={card.count}
        editorHref={editorHref}
      />
    ))
  }
</section>
