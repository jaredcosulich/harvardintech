---
// The dashboard's top row: the "Dashboard" heading with a one-line content
// summary on the left, and the primary "Open content editor" action on the
// right. The summary sentence (including the empty-state nudge and singular /
// plural grammar) comes from the pure `dashboardSummaryText` helper.
import { dashboardSummaryText } from '../../lib/adminDashboard';

interface Props {
  total: number;
  collectionCount: number;
  editorHref: string;
}
const { total, collectionCount, editorHref } = Astro.props;
const summary = dashboardSummaryText(total, collectionCount);
---

<div
  style="display: flex; align-items: flex-end; justify-content: space-between; flex-wrap: wrap; gap: var(--space-md); margin-bottom: var(--space-lg);"
>
  <div>
    <h1 style="font-size: 1.8rem; margin: 0 0 var(--space-sm);">Dashboard</h1>
    <p style="margin: 0; color: var(--color-muted);">{summary}</p>
  </div>
  <a class="s-btn" href={editorHref}>Open content editor →</a>
</div>
