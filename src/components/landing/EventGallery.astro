---
// "PHOTOS FROM LATEST HARVARD IN TECH EVENTS" — a grid of real event photos.
// Defaults to the locally-hosted set under /public/images/gallery (downloaded
// from the original site); accepts an `images` override for scenarios.
import { withBase } from '../../lib/url';
interface Props {
  images?: string[];
}
const defaults = Array.from(
  { length: 12 },
  (_, i) => `/images/gallery/event-${String(i + 1).padStart(2, '0')}.jpg`,
);
const { images = defaults } = Astro.props;
---

<section class="s-section" id="gallery">
  <div class="s-inner">
    <h2 class="s-title">Photos from Latest Harvard in Tech Events</h2>
    <div style="display: grid; gap: var(--space-sm); grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); max-width: 1000px; margin: 0 auto;">
      {
        images.map((src, i) => (
          <figure style="margin: 0; aspect-ratio: 4 / 3; border-radius: var(--radius); overflow: hidden; background: var(--color-bg-soft);">
            <img
              src={withBase(src)}
              alt={`Harvard in Tech event photo ${i + 1}`}
              loading="lazy"
              style="width: 100%; height: 100%; object-fit: cover; display: block;"
            />
          </figure>
        ))
      }
    </div>
  </div>
</section>
