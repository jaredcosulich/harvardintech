---
// Top section "HARVARD ALUMNI IN TECH" — faithful to harvardintech.com: a
// full-bleed background photo with a dark overlay and light text, the mission
// paragraph, and a SUBSCRIBE button to the MailChimp signup. The background is
// rendered as an <img> (survives the preview reverse-proxy / base-path rewrite).
import { withBase } from '../../lib/url';
interface Props {
  description?: string;
  subscribeUrl?: string;
  image?: string;
}
const {
  description = 'We are the official Harvard Alumni Group for technology. We hope to further the development of technology through encouraging innovation, providing Harvard alumni technologists with resources and networks, and promoting technological activity throughout the Harvard community. We are currently active in New York City and will be growing chapters in other cities. To stay up to date about future events, please sign up for our mailing list:',
  subscribeUrl = 'https://mailchi.mp/0222623e1169/fbrj32e9wb',
  image = '/images/bg/hero-bg.jpg',
} = Astro.props;
---

<section class="hero" id="about" data-parallax-root>
  <div style="position: absolute; inset: 0; overflow: hidden; z-index: 0;">
    <img
      src={withBase(image)}
      alt=""
      data-parallax
      style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;"
    />
    <div style="position: absolute; inset: 0; background: rgba(0, 0, 0, 0.39);"></div>
  </div>

  <div class="hero-inner">
    <h2 class="hero-title">Harvard Alumni in Tech</h2>
    <p class="hero-text">{description}</p>
    <div class="hero-cta">
      <a class="s-btn" href={subscribeUrl} rel="noopener">Subscribe</a>
    </div>
  </div>
</section>

<script>
  import { initParallax } from '../../lib/parallax';
  initParallax();
</script>

<style>
  .hero {
    position: relative;
    box-sizing: border-box;
    /* Fill the first screen below the header. `min-height` (not `height`) so
       tall content never clips on short screens; `svh` avoids the mobile
       address-bar jump, with a `vh` fallback for browsers without `svh`. */
    min-height: calc(100vh - var(--header-height));
    min-height: calc(100svh - var(--header-height));
    padding: 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
  .hero-inner {
    position: relative;
    z-index: 2;
    max-width: 918px;
    margin: 0 auto;
    color: #fff;
  }
  .hero-title {
    text-transform: uppercase;
    font-family: var(--font-title);
    font-weight: 400;
    color: #fff;
    font-size: 58px;
    line-height: 1.2;
    letter-spacing: normal;
    white-space: nowrap;
    margin: 0 0 1.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  /* "fresh" theme title decoration: 80x2px white rules flanking the text */
  .hero-title::before,
  .hero-title::after {
    content: '';
    flex: none;
    width: 80px;
    height: 2px;
    margin: 0 10px;
    background: #fff;
  }
  .hero-text {
    font-family: var(--font-sans);
    font-size: 20px;
    font-weight: 400;
    line-height: 29px;
    color: #fff;
    text-align: left;
    margin: 0 0 1.5rem;
  }
  .hero-cta {
    text-align: center;
  }

  /* Mobile: match the real site — the title scales down, wraps to multiple
     lines left-aligned, and the flanking rules collapse to a single underline
     beneath it; the Subscribe button goes full-width. */
  @media (max-width: 640px) {
    .hero {
      /* Keep the shared full-viewport `min-height`; just restore the mobile
         horizontal padding. Content stays flex-centered. */
      padding: 24px;
    }
    .hero-title {
      display: block;
      text-align: left;
      white-space: normal;
      font-size: 36px;
      line-height: 1.15;
      margin: 0 0 1.5rem;
    }
    .hero-title::before {
      display: none;
    }
    .hero-title::after {
      display: block;
      width: 80px;
      margin: 1rem 0 0;
    }
    .hero-text {
      font-size: 17px;
      line-height: 26px;
    }
    .hero-cta :global(.s-btn) {
      display: block;
      width: 100%;
    }
  }
</style>
