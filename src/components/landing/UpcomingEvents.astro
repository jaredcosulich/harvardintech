---
// "UPCOMING EVENTS" — renders the `events` content collection as cards. Accepts
// a plain array so it works from getCollection() on the homepage and from
// isolated-component scenarios (empty / sparse / rich / long-title states).
interface EventData {
  slug?: string;
  title: string;
  date: string | Date;
  location?: string;
  description?: string;
  link?: string;
}
interface Props {
  events?: EventData[];
  eventbriteUrl?: string;
}
const {
  events = [],
  eventbriteUrl = 'https://www.eventbrite.com/o/harvard-in-tech-17275560304',
} = Astro.props;

function fmtDate(d: string | Date): string {
  const date = d instanceof Date ? d : new Date(d);
  return date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
}
---

<section class="s-section" id="events">
  <div class="s-inner" style="text-align: center;">
    <h2 class="s-title">Upcoming Events</h2>
    {
      events.length === 0 ? (
        <p style="color: var(--color-muted);">
          No upcoming events right now — sign up for our mailing list to hear about the next one.
        </p>
      ) : (
        <div style="display: grid; gap: var(--space-lg); grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); max-width: 920px; margin: 0 auto;">
          {events.map((event) => (
            <article style="border: 1px solid var(--color-border); border-radius: var(--radius); padding: var(--space-lg); display: flex; flex-direction: column; text-align: left;">
              <time style="color: var(--color-accent); font-weight: 500; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.06em;">
                {fmtDate(event.date)}
              </time>
              <h3 style="margin: var(--space-sm) 0; font-size: 1.2rem;">{event.title}</h3>
              {event.location ? (
                <p style="color: var(--color-faint); margin: 0 0 var(--space-sm); font-size: 0.9rem;">{event.location}</p>
              ) : null}
              {event.description ? (
                <p style="color: var(--color-muted); margin: 0 0 var(--space-md);">{event.description}</p>
              ) : null}
              {event.link ? (
                <a href={event.link} rel="noopener" style="margin-top: auto; font-weight: 500;">
                  Learn more →
                </a>
              ) : null}
            </article>
          ))}
        </div>
      )
    }
    <div style="margin-top: var(--space-lg);">
      <a class="s-btn" href={eventbriteUrl} rel="noopener">View Upcoming Events</a>
    </div>
  </div>
</section>
