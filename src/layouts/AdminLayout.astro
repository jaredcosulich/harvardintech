---
// The CRM admin shell — the counterpart to BaseLayout for the /admin area. Owns
// the <head> (noindex meta, fonts, title), the soft-grey body, the admin header
// chrome, and the centered content column. Pages under /admin compose their
// sections into the <slot/>. noindex — an editing surface, never content.
import '../styles/tokens.css';
import AdminHeader from '../components/admin/AdminHeader.astro';
import { settings } from '../lib/site';

interface Props {
  title?: string;
}
const { title } = Astro.props;
const pageTitle = title
  ? `${title} · ${settings.siteTitle}`
  : `Content Manager · ${settings.siteTitle}`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>{pageTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body style="background: var(--color-bg-soft); min-height: 100vh;">
    <AdminHeader siteTitle={settings.siteTitle} />
    <main style="max-width: var(--content-width); margin: 0 auto; padding: var(--space-xl) var(--space-lg);">
      <slot />
    </main>
  </body>
</html>
