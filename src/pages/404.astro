---
import '../styles/tokens.css';
import { withBase } from '../lib/url';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Page Not Found - 404</title>
  </head>
  <body>
    <main style="max-width: var(--content-width); margin: 0 auto; padding: var(--space-lg); text-align: center; margin-top: 100px;">
      <h1 style="font-size: 3rem; margin-bottom: var(--space-sm);">404</h1>
      <p style="font-size: 1.25rem; color: var(--color-muted); margin-bottom: var(--space-lg);">
        Oops! The page you are looking for does not exist.
      </p>
      <a href={withBase('/')} style="font-size: 1.125rem; font-weight: 600; text-decoration: underline; color: var(--color-primary, #0066cc);">
        Go back home
      </a>
    </main>
  </body>
</html>
