---
import { getCollection, type CollectionEntry } from 'astro:content';
import '../../styles/tokens.css';

// Static output needs every dynamic route enumerated at build time.
// `getStaticPaths` turns each blog entry into a pre-rendered `/blog/<slug>` page.
export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

type Props = { post: CollectionEntry<'blog'> };
const { post } = Astro.props as Props;
const { Content } = await post.render();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{post.data.title}</title>
  </head>
  <body>
    <main style="max-width: var(--content-width); margin: 0 auto; padding: var(--space-lg);">
      <a href="/">&larr; All posts</a>
      <article style="margin-top: var(--space-lg);">
        <h1 style="margin-bottom: var(--space-sm);">{post.data.title}</h1>
        <time style="color: var(--color-muted);" datetime={post.data.date.toISOString()}>
          {post.data.date.toLocaleDateString()}
        </time>
        <div style="margin-top: var(--space-lg);">
          <Content />
        </div>
      </article>
    </main>
  </body>
</html>
