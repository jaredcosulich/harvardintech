---
// /chapters/<slug> — one page per regional chapter. Static output enumerates a
// route per `chapters` collection entry via getStaticPaths; ChapterPage renders
// the frontmatter (city, leads, links) and the markdown body in its slot.
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ChapterPage from '../../components/ChapterPage.astro';
import { splitEvents, type EventLike } from '../../lib/events';

export async function getStaticPaths() {
  const chapters = await getCollection('chapters');
  return chapters.map((chapter) => ({
    params: { slug: chapter.id },
    props: { chapter },
  }));
}

type Props = { chapter: CollectionEntry<'chapters'> };
const { chapter } = Astro.props as Props;
const { Content } = await render(chapter);
const { city, region, blurb, heroImage, tagline, showGallery, contactEmail, leads, links } = chapter.data;

// Upcoming events explicitly tagged to this chapter (soonest first). Events with
// no `chapter` (e.g. the Cambridge panel) belong to no chapter and are excluded.
const events = await getCollection('events');
const chapterEvents: EventLike[] = events
  .filter((event) => event.data.chapter === chapter.id)
  .map((event) => ({
    slug: event.id,
    title: event.data.title,
    date: event.data.date,
    location: event.data.location,
    description: event.data.description,
    link: event.data.link,
  }));
const { upcoming } = splitEvents(chapterEvents);
---

<BaseLayout title={city} description={blurb ?? `Harvard in Tech ${city} chapter.`}>
  <ChapterPage
    city={city}
    region={region}
    blurb={blurb}
    heroImage={heroImage}
    tagline={tagline}
    showGallery={showGallery}
    events={upcoming}
    contactEmail={contactEmail}
    leads={leads}
    links={links}
  >
    <Content />
  </ChapterPage>
</BaseLayout>
