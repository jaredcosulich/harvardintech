---
import Greeting from '../../components/Greeting.tsx';
import EmbedForm from '../../components/EmbedForm.astro';
import EventsPage from '../../components/EventsPage.astro';
import ChapterPage from '../../components/ChapterPage.astro';
import CollectionCountCard from '../../components/admin/CollectionCountCard.astro';
import DashboardSummary from '../../components/admin/DashboardSummary.astro';
import '../../styles/tokens.css';

// Component-isolation harness. codeyam captures a single component in isolation
// by navigating to `/isolated-components/<Name>` and screenshotting the
// `#codeyam-capture` wrapper. Add new entries to make a component isolable.
//
// Two flavors: React islands (hydrated via `client:load`) and static Astro
// components (server-rendered, no hydration). Static output enumerates routes
// at build time, so every name is a pre-rendered page via `getStaticPaths`.
const islands = {
  Greeting: { Component: Greeting, props: { name: 'Preview', subtitle: 'Isolated island' } },
} as const;

// Static Astro components. A prerendered page can't read `?s=` query params at
// render time, so each visual state is its own route name (`EmbedForm`,
// `EmbedForm-Embedded`, `EmbedForm-Unconfigured`) enumerated in getStaticPaths.
const embedFormStates = {
  Configured: {
    action: 'https://harvardintech.us1.list-manage.com/subscribe/post?u=abc123&id=def456',
    title: 'Join the Harvard in Tech newsletter',
    buttonLabel: 'Subscribe',
  },
  Embedded: {
    embedUrl: 'https://docs.google.com/forms/d/e/EXAMPLE_FORM_ID/viewform?embedded=true',
    title: 'RSVP — Harvard in Tech Summit 2026',
  },
  Unconfigured: {
    title: 'Subscribe',
  },
} as const;

// EventsPage states. `now` is fixed so the Upcoming/Past split is deterministic
// regardless of the build date. The Empty state proves the no-events fallback.
const SAMPLE_EVENTS = [
  {
    title: 'Harvard in Tech Summit 2026',
    date: '2026-09-24',
    location: 'New York, NY',
    description: 'Our flagship annual gathering of Harvard founders, operators, and investors.',
    link: 'https://www.harvardintech.com/events/summit-2026',
  },
  {
    title: 'Founders & Investors Mixer — San Francisco',
    date: '2026-07-15',
    location: 'San Francisco, CA',
    description: 'An evening connecting Harvard alumni founders with active investors across the Bay Area.',
    link: 'https://www.harvardintech.com/events/sf-mixer',
  },
  {
    title: 'Spring Founder Dinner — NYC',
    date: '2026-03-12',
    location: 'New York, NY',
    description: 'An intimate dinner with Harvard alumni founders and operators.',
    link: 'https://www.harvardintech.com/events/spring-founder-dinner',
  },
];
// NOTE: no `as const` — these fixtures feed components whose props are mutable
// arrays (`EventLike[]`), so a deeply-readonly literal would fail the type check.
const eventsPageStates = {
  Default: { events: SAMPLE_EVENTS, now: '2026-06-13' },
  Empty: { events: [] as typeof SAMPLE_EVENTS, now: '2026-06-13' },
};

// ChapterPage states: a full NYC-style chapter vs a sparse one (city + region
// only, no blurb / leads / links) proving the missing-optional layout.
const chapterPageStates = {
  Default: {
    city: 'New York City',
    region: 'New York, NY',
    blurb: 'Our founding chapter and largest community, hosting monthly mixers, founder dinners, and the annual Harvard in Tech Summit.',
    leads: [
      { name: 'Jessica Li', role: 'Chapter Lead' },
      { name: 'Ben Wei', role: 'Events' },
    ],
    links: [
      { label: 'Join the NYC WhatsApp', url: 'https://chat.whatsapp.com/harvardintech-nyc' },
      { label: 'NYC events on Eventbrite', url: 'https://www.eventbrite.com/o/harvard-in-tech-17275560304' },
    ],
  },
  Sparse: {
    city: 'Japan',
    region: 'Tokyo',
  },
};

// CollectionCountCard states: a populated count (links into the editor) vs an
// empty collection (count 0 → the "No entries yet" note). `editorHref` mirrors
// the real dashboard link.
const ADMIN_EDITOR_HREF = '/admin/editor/index.html';
const collectionCountCardStates = {
  Default: { collection: 'events' as const, label: 'Events', count: 3, editorHref: ADMIN_EDITOR_HREF },
  Empty: { collection: 'blog' as const, label: 'Blog', count: 0, editorHref: ADMIN_EDITOR_HREF },
};

// DashboardSummary states: a populated summary (total + collection count) vs the
// empty-state nudge shown when there is no content at all.
const dashboardSummaryStates = {
  Default: { total: 14, collectionCount: 5, editorHref: ADMIN_EDITOR_HREF },
  Empty: { total: 0, collectionCount: 5, editorHref: ADMIN_EDITOR_HREF },
};

export async function getStaticPaths() {
  // getStaticPaths runs in an isolated scope and cannot reference the
  // module-level consts — enumerate route names inline.
  return [
    { params: { name: 'Greeting' } },
    { params: { name: 'EmbedForm' } },
    { params: { name: 'EmbedForm-Embedded' } },
    { params: { name: 'EmbedForm-Unconfigured' } },
    { params: { name: 'EventsPage' } },
    { params: { name: 'EventsPage-Empty' } },
    { params: { name: 'ChapterPage' } },
    { params: { name: 'ChapterPage-Sparse' } },
    { params: { name: 'CollectionCountCard' } },
    { params: { name: 'CollectionCountCard-Empty' } },
    { params: { name: 'DashboardSummary' } },
    { params: { name: 'DashboardSummary-Empty' } },
  ];
}

const { name } = Astro.params;
// The `islands` registry above holds each hydrated island's preview props. The
// island component itself is rendered DIRECTLY in the template below (not
// through a variable). Astro generates a `client:*` hydration script by
// statically tracing the rendered component back to its import; a component
// referenced through a runtime variable (`<Island />`) can't be traced and
// fails the static build with `[NoMatchingImport]`. Adding a hydrated island
// therefore means BOTH a registry entry here AND a direct render branch.

// Resolve the EmbedForm visual state from the route name suffix.
let embedFormProps: (typeof embedFormStates)[keyof typeof embedFormStates] | null = null;
if (name && name.startsWith('EmbedForm')) {
  const stateKey = (name === 'EmbedForm' ? 'Configured' : name.slice('EmbedForm-'.length)) as keyof typeof embedFormStates;
  embedFormProps = embedFormStates[stateKey] ?? embedFormStates.Configured;
}

let eventsPageProps: (typeof eventsPageStates)[keyof typeof eventsPageStates] | null = null;
if (name && name.startsWith('EventsPage')) {
  const stateKey = (name === 'EventsPage' ? 'Default' : name.slice('EventsPage-'.length)) as keyof typeof eventsPageStates;
  eventsPageProps = eventsPageStates[stateKey] ?? eventsPageStates.Default;
}

let chapterPageProps: (typeof chapterPageStates)[keyof typeof chapterPageStates] | null = null;
if (name && name.startsWith('ChapterPage')) {
  const stateKey = (name === 'ChapterPage' ? 'Default' : name.slice('ChapterPage-'.length)) as keyof typeof chapterPageStates;
  chapterPageProps = chapterPageStates[stateKey] ?? chapterPageStates.Default;
}

let collectionCountCardProps: (typeof collectionCountCardStates)[keyof typeof collectionCountCardStates] | null = null;
if (name && name.startsWith('CollectionCountCard')) {
  const stateKey = (name === 'CollectionCountCard' ? 'Default' : name.slice('CollectionCountCard-'.length)) as keyof typeof collectionCountCardStates;
  collectionCountCardProps = collectionCountCardStates[stateKey] ?? collectionCountCardStates.Default;
}

let dashboardSummaryProps: (typeof dashboardSummaryStates)[keyof typeof dashboardSummaryStates] | null = null;
if (name && name.startsWith('DashboardSummary')) {
  const stateKey = (name === 'DashboardSummary' ? 'Default' : name.slice('DashboardSummary-'.length)) as keyof typeof dashboardSummaryStates;
  dashboardSummaryProps = dashboardSummaryStates[stateKey] ?? dashboardSummaryStates.Default;
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Isolated: {name}</title>
  </head>
  <body>
    <div id="codeyam-capture" style="padding: var(--space-lg);">
      {
        name === 'Greeting' ? (
          <Greeting {...islands.Greeting.props} client:load />
        ) : embedFormProps ? (
          <EmbedForm {...embedFormProps} />
        ) : eventsPageProps ? (
          <EventsPage {...eventsPageProps} />
        ) : chapterPageProps ? (
          <ChapterPage {...chapterPageProps}>
            <p>
              A representative "about this chapter" paragraph rendered in the
              markdown body slot, so the isolated capture matches the real route.
            </p>
          </ChapterPage>
        ) : collectionCountCardProps ? (
          <div style="width: 240px; background: var(--color-bg-soft); padding: var(--space-md);">
            <CollectionCountCard {...collectionCountCardProps} />
          </div>
        ) : dashboardSummaryProps ? (
          <div style="width: 760px; max-width: 100%; background: var(--color-bg-soft); padding: var(--space-lg);">
            <DashboardSummary {...dashboardSummaryProps} />
          </div>
        ) : (
          <p>Unknown component: {name}</p>
        )
      }
    </div>
  </body>
</html>
