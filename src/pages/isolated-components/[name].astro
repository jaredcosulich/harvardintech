---
import Greeting from '../../components/Greeting.tsx';
import '../../styles/tokens.css';

// Component-isolation harness. codeyam captures a single React island in
// isolation by navigating to `/isolated-components/<Name>` and screenshotting
// the `#codeyam-capture` wrapper. Each island gets a default-props render here;
// add new islands to the `islands` map below to make them isolable.
//
// Static output enumerates routes at build time, so every island name is a
// pre-rendered page via `getStaticPaths`.
const islands = {
  Greeting: { Component: Greeting, props: { name: 'Preview', subtitle: 'Isolated island' } },
} as const;

export async function getStaticPaths() {
  return Object.keys({
    Greeting: true,
  }).map((name) => ({ params: { name } }));
}

const { name } = Astro.params;
const entry = islands[name as keyof typeof islands];
const Island = entry?.Component;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Isolated: {name}</title>
  </head>
  <body>
    <div id="codeyam-capture" style="padding: var(--space-lg);">
      {Island ? <Island {...entry.props} client:load /> : <p>Unknown component: {name}</p>}
    </div>
  </body>
</html>
